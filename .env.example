DATABASE_URL=postgres://user:password@localhost:5432/invoice_app
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-generated-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Comma-separated list of allowed Gmail addresses (e.g. 4 employees)
ALLOWED_GOOGLE_EMAILS=first@gmail.com,second@gmail.com,third@gmail.com,fourth@gmail.com

# In Google Cloud Console (APIs & Services > Credentials > your OAuth 2.0 Client):
# Add Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# If dev server runs on another port (e.g. 3001), use that port in NEXTAUTH_URL and in the redirect URI.

